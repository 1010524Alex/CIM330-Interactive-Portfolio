  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: 'For This Project I used the TWINE Engine to create a text based adventure.
    Having an interest in the Sci-Fi and Film Noir Genre, I decided to create a detective
    game that is interrogation based. While all audio is outsourced from various
    royalty free websites all photographs were done by hand. Unsatisfied with using
    royalty free images, with the assistance of a friend and acquaintance in media,
    Nick Koniuszuko. we used practical effects such as miniature mannequins, fake
    blood and forced perspective to create still images that could provide an immersive
    experience.  '
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
